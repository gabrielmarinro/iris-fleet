                    <td className="px-3 py-2 text-sm">{v.conductor}</td>
                    <td className="px-3 py-2 text-sm font-semibold">{v.origen} → {v.destino}<br/><span className="text-xs text-gray-500">Próx: {v.proximaParada}</span></td>
